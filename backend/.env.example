# --- AI provider selection -------------------------------------------------
# One of: groq | anthropic | gemini
AI_PROVIDER=groq

# --- Model name ------------------------------------------------------------
# IMPORTANT: confirm the current model id from your provider's docs.
# Defaults below are sensible starting points; they may be renamed over time.
#
# Groq        -> llama-3.3-70b-versatile   (free tier, fast Llama 3.3 70B)
# Anthropic   -> claude-sonnet-4-5         (check https://docs.anthropic.com)
# Gemini      -> gemini-2.0-flash          (check https://ai.google.dev/gemini-api/docs/models)
MODEL=llama-3.3-70b-versatile

# Optional: override the model used by the chat endpoint specifically.
# Falls back to MODEL if unset. Useful if you want a cheaper model for chat
# than for scoring (or vice versa).
# CHAT_MODEL=

# --- API keys (only set the one matching AI_PROVIDER) ----------------------
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Embeddings (for RAG / dashboard chat) ---------------------------------
# Groq has no embedding API, so embeddings use a separate provider.
# One of: google | voyage | local
#
#   google  -> text-embedding-004,      768 dims. Free tier ~1500 RPM. Reuses GEMINI_API_KEY.
#   voyage  -> voyage-3-lite,           512 dims. Needs VOYAGE_API_KEY. Small free trial only.
#   local   -> Xenova/all-MiniLM-L6-v2, 384 dims. NO API KEY, NO RATE LIMITS.
#              Runs in-process via Transformers.js. First call downloads ~23 MB
#              of model weights to your HF cache; after that it's offline.
#              Best pick if you want zero external dependencies.
EMBED_PROVIDER=google

# Default models per provider (override only if you know what you're doing):
#   google -> text-embedding-004
#   voyage -> voyage-3-lite
#   local  -> Xenova/all-MiniLM-L6-v2
#            (good local alternatives: Xenova/bge-small-en-v1.5,
#             Xenova/multilingual-e5-small -- both 384 dims)
# EMBED_MODEL=

# Vector dimension. MUST match the model's output dim AND the Pinecone index's
# dimension (fixed at index-creation time). To CHANGE dim:
#   1. set EMBED_DIM to the new value
#   2. set a NEW PINECONE_INDEX name (a Pinecone index can't change its dim)
#   3. run `node reindex.js` to re-embed every resume into the new index
#
# Provider defaults: google=768, voyage=512, local=384
EMBED_DIM=768

# Provider key for embeddings. If EMBED_PROVIDER=google, reuses GEMINI_API_KEY
# above. If EMBED_PROVIDER=voyage, set VOYAGE_API_KEY here. If 'local', leave blank.
VOYAGE_API_KEY=

# --- Chunking (rarely needs tuning) ---------------------------------------
# CHUNK_TARGET_WORDS=250
# CHUNK_OVERLAP_WORDS=40

# --- MongoDB (REQUIRED — the source of truth) ------------------------------
# MongoDB stores everything: resumes, resume text-chunks, chat threads/messages,
# and the automation suite (workflows, runs, interviewers, OA templates, tokens).
# The server connects at boot and FAILS LOUDLY if MONGODB_URI is unset or
# unreachable — there is no SQLite fallback. A free Atlas M0 cluster works.
#   MONGODB_URI=mongodb+srv://USER:PASS@cluster.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
# Database name inside the cluster (default: resume_scorer).
MONGODB_DB=resume_scorer

# --- Pinecone (REQUIRED — the only vector store) ---------------------------
# Embeddings live ONLY in Pinecone (chunk TEXT lives in MongoDB). Vector search
# queries Pinecone and hydrates text from Mongo by chunk id. If Pinecone is
# unreachable the semantic signal is skipped and chat still answers from the
# Mongo $text (BM25) keyword signal — so set this for full retrieval quality.
#
# Free tier (serverless): 2GB storage, 2M write units / 1M read units per
# month, 5 indexes max. The index is auto-created on first use with the
# settings below (free tier requires aws/us-east-1).
PINECONE_API_KEY=
PINECONE_INDEX=resume-chunks
PINECONE_NAMESPACE=default
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- IMAP (read resumes from a custom-domain mailbox) ----------------------
# Optional. Lets the backend pull resume attachments out of ANY mailbox that
# speaks IMAP (Zoho, Google Workspace, Microsoft 365, Hostinger, cPanel, ...) --
# the provider-neutral alternative to the Outlook / Gmail OAuth flows.
#
# These can also be set from the dashboard (POST /imap/config); the dashboard
# values, when present, override what's here. Prefer keeping the PASSWORD here
# in .env (git-ignored) rather than saving it through the UI.
#
# Use a provider APP PASSWORD, not your normal login password, and make sure
# IMAP access is enabled in the mailbox's settings.
#
# Free ways to test:
#   - Gmail:  IMAP_HOST=imap.gmail.com   (enable 2FA -> create an App Password)
#   - Zoho:   IMAP_HOST=imap.zoho.com    (Forever-Free plan gives a real custom
#                                          domain mailbox at no cost)
#   - M365:   IMAP_HOST=outlook.office365.com
#
# IMAP_HOST=imap.zoho.com
# IMAP_PORT=993            # 993 = implicit TLS (set IMAP_SECURE=true); 143 = STARTTLS (false)
# IMAP_SECURE=true
# IMAP_USER=hr@yourcompany.com
# IMAP_PASS=your-app-password
# IMAP_MAILBOX=INBOX

# --- Server ---------------------------------------------------------------
PORT=8787

# Legacy: path to the old SQLite file. Only read by the one-time
# `node migrate-to-mongo.js` importer; the server itself never uses it.
# Defaults to backend/data.db.
# DB_PATH=
